# ──────────────────────────────────────────────────────────────────
# RetailCRM
# ──────────────────────────────────────────────────────────────────
# URL твоего магазина без слеша на конце, например: https://demo-store.retailcrm.ru
RETAILCRM_URL=
# API key v5. Settings → Integration → API access keys → Create.
# Permissions: order_read, order_write, reference_read
RETAILCRM_API_KEY=
# siteCode магазина (Settings → Stores). Если магазин один — обычно совпадает с поддоменом.
RETAILCRM_SITE=

# ──────────────────────────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Account → Access Tokens (для Supabase MCP и CLI миграций)
SUPABASE_ACCESS_TOKEN=
# Project ref (часть URL: <ref>.supabase.co)
SUPABASE_PROJECT_REF=
# service_role key — НИКОГДА не коммитим, используется только в server-side кода
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────────────
# Telegram
# ──────────────────────────────────────────────────────────────────
# От @BotFather: 123456:ABC...
TELEGRAM_BOT_TOKEN=
# Username бота без @, например: gbc_orders_bot
TELEGRAM_BOT_USERNAME=
# Твой личный chat_id для первого теста
TELEGRAM_TEST_CHAT_ID=
# Секрет для верификации входящих webhook'ов от Telegram (любая случайная строка)
TELEGRAM_WEBHOOK_SECRET=

# ──────────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────────
# Порог для уведомления о крупном заказе (тенге)
ORDER_ALERT_THRESHOLD_KZT=50000
# Публичный URL продакшн-приложения на Vercel (заполнится после первого деплоя)
NEXT_PUBLIC_APP_URL=
